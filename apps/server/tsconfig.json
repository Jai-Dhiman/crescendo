{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext"],
    "types": ["@cloudflare/workers-types"],
    "moduleResolution": "bundler",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@crescendo/shared-types": ["../../packages/shared-types/src"],
      "@crescendo/validation": ["../../packages/validation/src"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "../../packages/shared-types" }, { "path": "../../packages/validation" }]
}
